<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card shadow-lg border-0 rounded-4">
                
                <div class="card-header bg-primary text-white text-center rounded-top-4">
                    <h4 class="mb-0">
                        <i class="fas fa-pen-nib me-2"></i> Create New Blog
                    </h4>
                </div>

                <div class="card-body p-4">

                    <form method="POST" action="/blogs/author/create">

                        <!-- Title -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Blog Title</label>
                            <input 
                                type="text" 
                                name="title" 
                                style="color: aliceblue;"
                                class="form-control rounded-3" 
                                placeholder="Enter blog title"
                                required>
                        </div>

                        <!-- Content -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Blog Content</label>
                            <textarea 
                                name="content" 
                                class="form-control rounded-3" 
                                 style="color: aliceblue;"
                                rows="6" 
                                placeholder="Write your blog content here..."
                                required></textarea>
                        </div>

                        <!-- Button -->
                        <div class="d-grid">
                            <button type="submit" class="btn btn-dark rounded-3" style="background-color: crimson;">
                                <i class="fas fa-paper-plane me-2"></i> Publish Blog
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>