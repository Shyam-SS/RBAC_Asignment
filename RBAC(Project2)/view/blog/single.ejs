

<div class="container">

    <div class="card p-5 mb-4">
        <h2><%= blog.title %></h2>

        <p class="text-muted">
            By <strong><%= blog.author.name %></strong>
        </p>

        <hr>

        <p><%= blog.content %></p>
    </div>

    <!-- COMMENTS -->
    <div class="card p-4 mb-4">
        <h5>Comments</h5>

        <% if (comments.length === 0) { %>
            <p class="text-muted">Be the first to comment.</p>
        <% } %>

        <% comments.forEach(comment => { %>
            <div class="mb-3 border-bottom pb-2">
                <strong><%= comment.user.name %></strong>
                <p><%= comment.text %></p>
            </div>
        <% }) %>
    </div>

    <% if(user){ %>
    <div class="card p-4">
        <h5>Write a Comment</h5>

        <form action="/comment/<%= blog._id %>" method="POST">
            <textarea name="text" 
                      class="form-control mb-3" 
                      rows="3" 
                      required></textarea>

            <button class="btn btn-success">
                Post Comment
            </button>
        </form>
    </div>
    <% } %>

</div>