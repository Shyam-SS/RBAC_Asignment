<!DOCTYPE html>
<html>

<head>
  <title>Register</title>
  <link href="/css/style.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="auth-wrapper">

  <div class="auth-card">
    <h3>Create Account</h3>


    <% if(error){ %>
      <div class="alert alert-danger text-center">
        <%= error %>
      </div>
      <% } %>

        <% if(success){ %>
          <div class="alert alert-success text-center">
            <%= success %>
          </div>
          <% } %>

            <form id="registerForm">

              <div class="mb-3">
                <label>Name</label>
                <input type="text" name="name" class="form-control" required>
              </div>

              <div class="mb-3">
                <label>Email</label>
                <input type="email" name="email" class="form-control" required>
              </div>

              <div class="mb-3">
                <label>Password</label>
                <input type="password" name="password" class="form-control" required>
              </div>

              <button class="auth-btn" type="submit">Register</button>

              <p class="auth-link">
                Already have an account?
                <a href="/login">Login</a>
              </p>
            </form>
  </div>

  <!-- OTP MODAL -->
  <div id="otpModal" class="otp-overlay">
    <div class="otp-box">
      <h5 class="mb-3 text-light">Verify Your Email</h5>

      <div class="otp-inputs">
        <input maxlength="1">
        <input maxlength="1">
        <input maxlength="1">
        <input maxlength="1">
        <input maxlength="1">
        <input maxlength="1">
      </div>

      <p class="mt-3 text-light">
        Time left: <span id="timer">60</span>s
      </p>

      <button id="verifyOtpBtn" class="auth-btn mt-2">Verify</button>

      <button id="resendBtn" class="btn btn-link text-light mt-2">
        Resend OTP
      </button>
    </div>
  </div>

  <script>
    let userEmail = "";
    let countdown = null;
    let timeLeft = 60;

    const form = document.getElementById("registerForm");
    const otpModal = document.getElementById("otpModal");
    const timerDisplay = document.getElementById("timer");
    const resendBtn = document.getElementById("resendBtn");
    const inputs = document.querySelectorAll(".otp-inputs input");

    /* ================= REGISTER SUBMIT ================= */
    form.addEventListener("submit", async function (e) {
      e.preventDefault();

      // 🔥 SHOW MODAL INSTANTLY
      otpModal.style.display = "flex";
      document.body.style.overflow = "hidden";

      const formData = new FormData(form);

      const res = await fetch("/register", {
        method: "POST",
        body: new URLSearchParams(formData)
      });

      const data = await res.json();

      if (data.success) {
        userEmail = data.email;
        startTimer();
      } else {
        otpModal.style.display = "none";
        document.body.style.overflow = "auto";
        alert(data.message || "Email already registered");
      }
    });

    /* ================= OTP INPUT AUTO MOVE ================= */
    inputs.forEach((input, index) => {
      input.addEventListener("input", () => {
        if (input.value.length === 1 && index < inputs.length - 1) {
          inputs[index + 1].focus();
        }
      });

      input.addEventListener("keydown", (e) => {
        if (e.key === "Backspace" && !input.value && index > 0) {
          inputs[index - 1].focus();
        }
      });
    });

    /* ================= TIMER FIXED ================= */
    function startTimer() {

      if (countdown) {
        clearInterval(countdown);
      }

      timeLeft = 60;
      timerDisplay.innerText = timeLeft;

      resendBtn.disabled = true;
      resendBtn.style.opacity = "0.5";
      resendBtn.style.pointerEvents = "none";

      countdown = setInterval(() => {

        timeLeft--;

        if (timeLeft <= 0) {
          clearInterval(countdown);
          timerDisplay.innerText = "0";

          resendBtn.disabled = false;
          resendBtn.style.opacity = "1";
          resendBtn.style.pointerEvents = "auto";
          resendBtn.style.color = "#3b82f6";
          return;
        }

        timerDisplay.innerText = timeLeft;

      }, 1000);
    }

    /* ================= VERIFY OTP ================= */
    document.getElementById("verifyOtpBtn").addEventListener("click", async () => {

      let otp = "";
      inputs.forEach(input => otp += input.value);

      if (otp.length !== 6) {
        alert("Enter complete 6-digit OTP");
        return;
      }

      const res = await fetch("/verify-otp", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email: userEmail, otp })
      });

      const data = await res.json();

      if (data.success) {
        window.location.href = "/login";
      } else {
        alert(data.message || "Invalid OTP");
      }
    });

    /* ================= RESEND OTP ================= */
    resendBtn.addEventListener("click", async () => {

      if (resendBtn.disabled) return;

      const res = await fetch("/resend-otp", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email: userEmail })
      });

      const data = await res.json();

      if (data.success) {
        startTimer();
      } else {
        alert(data.message || "Error resending OTP");
      }
    });
  </script>

</body>

</html>